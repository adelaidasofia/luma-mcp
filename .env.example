# Luma API credentials. Generate at https://lu.ma/settings/api (requires Luma Plus subscription).
# Auth header is x-luma-api-key. One key per calendar.
LUMA_API_KEY=your-luma-api-key-here

# Optional: override the API base URL (default: https://api.lu.ma/public/v1)
# LUMA_API_BASE=https://api.lu.ma/public/v1

# Optional: override audit log path (default: ~/.claude/luma-mcp/audit.log)
# LUMA_AUDIT_LOG=/path/to/audit.log

# Optional: draft TTL in seconds (default: 3600 = 1 hour)
# LUMA_DRAFT_TTL=3600
